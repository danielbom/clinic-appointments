{
  "transforms": [
    {
      "mode": "sql",
      "include": "generated/queries/*.sql",
      "emitTemplate": "src/db/queries/{{name}}.ts"
    }
  ],
  "typesOverrides": { 
    "date": "string",
    "interval": "number",
    "numeric": "number"
  },
  "srcDir": ".",
  "failOnError": true,
  "camelCaseColumnNames": false,
  "db": {
    "dbName": "dev_db",
    "user": "dev_user",
    "password": "dev_password",
    "host": "localhost",
    "port": 5432
  }
}