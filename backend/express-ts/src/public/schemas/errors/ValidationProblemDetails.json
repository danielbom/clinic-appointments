      "$ref": "#/components/errors/ProblemDetails"
    },
    {
      "type": "object",
      "properties": {
        "code": {
          "type": "string",
          "enum": [
            "validation_error"
          ]
        },
        "status": {
          "type": "number",
          "enum": [
            400
          ]
        },
        "title": {
          "type": "string",
          "enum": [
            "Validation error"
          ]
        }
      },
      "required": [
        "code",
        "status",
        "title"
      ]
    }
  ]
}