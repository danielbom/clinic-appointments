generator client {
  provider = "prisma-client"
  output   = "../src/prisma"
  // previewFeatures = ["relationJoins"]
}

datasource db {
  provider = "postgresql"
}

model admins {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name     String @db.VarChar(255)
  email    String @unique(map: "idx_admins_email") @db.VarChar(255)
  password String @db.VarChar(255)
}

model appointments {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id     String        @db.Uuid
  specialist_id   String        @db.Uuid
  service_name_id String        @db.Uuid
  price           Int
  duration        Int
  date            DateTime      @db.Date
  time            DateTime      @db.Time(6)
  status          Int
  notified_at     DateTime?     @db.Timestamptz(6)
  notified_by     String?       @db.Uuid
  customers       customers     @relation(fields: [customer_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  service_names   service_names @relation(fields: [service_name_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  specialists     specialists   @relation(fields: [specialist_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([date(sort: Desc)])
}

model customers {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String         @db.VarChar(255)
  email        String?        @db.VarChar(255)
  phone        String         @unique(map: "idx_customers_phone") @db.VarChar(255)
  birthdate    DateTime       @db.Date
  cpf          String         @db.VarChar(11)
  appointments appointments[]
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model schema_version {
  version Int

  @@ignore
}

model secretaries {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @db.VarChar(255)
  email     String   @unique(map: "idx_secretaries_email") @db.VarChar(255)
  password  String   @db.VarChar(255)
  phone     String   @db.VarChar(255)
  birthdate DateTime @db.Date
  cpf       String   @db.VarChar(11)
  cnpj      String?  @db.VarChar(14)
}

model service_names {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name              String          @unique(map: "service_names_name_idx") @db.VarChar(255)
  specialization_id String          @db.Uuid
  appointments      appointments[]
  specializations   specializations @relation(fields: [specialization_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  services          services[]

  @@index([specialization_id])
}

model services {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  service_name_id String        @db.Uuid
  specialist_id   String        @db.Uuid
  price           Int
  duration        Int
  service_names   service_names @relation(fields: [service_name_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  specialists     specialists   @relation(fields: [specialist_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([service_name_id, specialist_id], map: "services_service_unique_idx")
  @@index([service_name_id])
  @@index([specialist_id])
}

model specialist_hours {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  specialist_id String      @db.Uuid
  weekday       Int
  start_time    DateTime    @db.Time(6)
  end_time      DateTime    @db.Time(6)
  specialists   specialists @relation(fields: [specialist_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model specialists {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String             @db.VarChar(255)
  email            String             @unique(map: "idx_specialists_email") @db.VarChar(255)
  phone            String             @db.VarChar(255)
  birthdate        DateTime           @db.Date
  cpf              String             @db.VarChar(11)
  cnpj             String?            @db.VarChar(14)
  appointments     appointments[]
  services         services[]
  specialist_hours specialist_hours[]
}

model specializations {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String          @unique(map: "specializations_name_idx") @db.VarChar(255)
  service_names service_names[]
}
